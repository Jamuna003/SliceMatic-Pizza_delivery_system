# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_API_KEY: Optional/alternative Google API key for Gemini model integrations.
# Use VITE_GOOGLE_API_KEY if exposing it to the client side in Vite builds on Vercel.
GOOGLE_API_KEY=""
VITE_GOOGLE_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE: Required for PizzaFlow real-time menu and order tracking (optional fallback provided).
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# OPENROUTER_API_KEY: Secure key for OpenRouter chat completions.
# Note: Set this in your Supabase Edge Function secrets, never expose to browser or client code.
# Run command: supabase secrets set OPENROUTER_API_KEY=your-api-key
OPENROUTER_API_KEY=""

